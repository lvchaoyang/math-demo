{
  "name": "math-demo-monorepo",
  "version": "1.0.0",
  "description": "数学试卷解析系统 - Monorepo",
  "private": true,
  "scripts": {
    "dev": "node scripts/prep-dev.mjs && concurrently \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:parser\"",
    "dev:web": "pnpm --filter @math-demo/web dev",
    "dev:api": "pnpm --filter @math-demo/api dev",
    "dev:parser": "node scripts/dev-parser.mjs",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @math-demo/web build",
    "build:api": "pnpm --filter @math-demo/api build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "test": "pnpm -r test",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "build:wmf-gdi": "dotnet build tools/wmf-gdi-render/WmfGdiRender.csproj -c Release"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}

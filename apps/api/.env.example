# API Server Configuration
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Parser Service URL（若解析器使用 PARSER_PORT 换端口，此处需一致，例如 http://localhost:8001）
PARSER_URL=http://localhost:8000

# File Storage
UPLOAD_DIR=uploads
EXPORT_DIR=exports

# Windows：WMF/EMF 公式图 GDI+ 栅格化（可选；不设则自动使用 tools/wmf-gdi-render 下已编译的 WmfGdiRender.exe）
# WMF_GDI_RENDER_EXE=E:\path\to\WmfGdiRender.exe

# 导出 Word 时 Node 等待 Python 的最长时间（毫秒），大卷重新解析可能较久，默认 600000（10 分钟）
# EXPORT_TIMEOUT_MS=600000
